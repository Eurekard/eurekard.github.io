rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'createdAt'])
        && data.uid == request.auth.uid
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 30
        && data.email == request.auth.token.email
        && data.createdAt is string; // or timestamp
    }

    function isValidCard(data) {
      return data.keys().hasAll(['uid', 'username', 'published_content', 'draft_content'])
        && data.uid == request.auth.uid
        && data.username is string;
    }

    function isValidResponse(data) {
      return data.keys().hasAll(['message', 'createdAt', 'status'])
        && data.message is string && data.message.size() <= 1000
        && data.status in ['unread', 'replied', 'archived', 'deleted']
        && (data.keys().size() == 3 || (data.keys().size() == 4 && data.keys().hasAll(['reply'])));
    }

    function isValidIsoString(s) {
      return s is string && s.size() <= 40;
    }

    function isVisitorStatsWrite() {
      // 注意：client 使用 FieldValue.increment 時，規則端以「寫入後最終數值」驗證；勿用 is int，部分專案會與 increment 不相容而全數擋下
      return incoming().keys().hasOnly(['visitorCount', 'updatedAt'])
        && isValidIsoString(incoming().updatedAt)
        && (
          !resource.exists
            ? incoming().visitorCount == 1
            : (incoming().visitorCount == existing().visitorCount + 1
              && incoming().updatedAt != existing().updatedAt)
        );
    }

    function isMoodStatsWrite() {
      return incoming().keys().hasOnly(['moodCount', 'updatedAt'])
        && isValidIsoString(incoming().updatedAt)
        && (
          !resource.exists
            ? incoming().moodCount == 1
            : (incoming().moodCount == existing().moodCount + 1
              && incoming().updatedAt != existing().updatedAt)
        );
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No blanket reads
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().username == existing().username
        && incoming().createdAt == existing().createdAt;
    }

    // 2. Card Content
    match /cards/{cardId} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(cardId) && isValidCard(incoming());
      allow update: if isOwner(cardId)

      // 2.0 Public element counters (visitor / mood)
      match /element_stats/{statId} {
        allow read: if true;
        allow create, update: if 
          incoming().diff(existing()).affectedKeys().hasOnly(['visitorCount', 'moodCount', 'updatedAt']) ||
          (
            incoming().keys().hasOnly(['visitorCount', 'moodCount', 'updatedAt'])
          );
        allow delete: if false;
      }
      
      // 2.1 Responses Subcollection
      match /responses/{responseId} {
        allow read: if isOwner(cardId);
        allow create: if incoming().message is string && incoming().message.size() <= 1000
          && incoming().status == 'unread';
        allow update: if isOwner(cardId)
          && incoming().message == existing().message
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reply'])
          && incoming().status in ['unread', 'replied', 'archived', 'deleted']
          && (!incoming().keys().hasAny(['reply']) || (incoming().reply is string && incoming().reply.size() <= 1000));
        allow delete: if isOwner(cardId);
      }
    }

    // 3. Usernames Reverse Lookup
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && isValidId(username) && incoming().uid == request.auth.uid;
      allow update, delete: if false;
    }

    // 4. Analytics
    match /analytics/{cardId} {
      allow read, write: if isOwner(cardId);

      match /events/{eventId} {
        allow read: if isOwner(cardId);
        allow create: if incoming().keys().hasAll(['type', 'day', 'device', 'source', 'createdAt'])
          && incoming().keys().hasOnly(['type', 'day', 'device', 'source', 'createdAt', 'targetId'])
          && incoming().type in ['view', 'click']
          && incoming().day is string
          && incoming().day.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && incoming().device in ['mobile', 'desktop']
          && incoming().source in ['direct', 'social', 'search', 'referral', 'unknown']
          && incoming().createdAt is string
          && incoming().createdAt.size() <= 40
          && (!incoming().keys().hasAny(['targetId']) || (incoming().targetId is string && incoming().targetId.size() <= 128));
        allow update, delete: if false;
      }
    }
  }
}
