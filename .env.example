# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare R2 image upload settings
# These are used by /api/upload-image.ts server-side endpoint.
CLOUDFLARE_R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
CLOUDFLARE_R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
CLOUDFLARE_R2_BUCKET_NAME="eurekard-images"
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://pub-22e0315e37b947088f3b32da7cffec0f.r2.dev

# Google Analytics 4 – Dashboard analytics reporting
# Used by /api/analytics-report.ts server-side endpoint.
#
# GA4_PROPERTY_ID: Numeric GA4 property ID (NOT the G-XXXXX measurement ID).
#   Find it at: analytics.google.com → Admin → Property Settings → Property ID
#   Example: "123456789"
GA4_PROPERTY_ID="YOUR_GA4_PROPERTY_ID"
#
# GA4_SERVICE_ACCOUNT_JSON: Full JSON content of a Google Cloud service account key.
#   1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#   2. Create a service account and download a JSON key
#   3. Grant it "Viewer" role in GA4: Admin → Property Access Management
#   Paste the entire JSON (minified) as the value of this variable.
GA4_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
